{
  "name": "@vspo-lab/utils",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "turbo build",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint --apply .",
    "biome:unsafe-fix": "biome check --fix --unsafe",
    "knip": "knip",
    "tsc": "pnpm -r exec tsc --noEmit",
    "textlint": "textlint \"{README.md,CLAUDE.md,AGENTS.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,CLAUDE.md,AGENTS.md,docs/**/*.md}\""
  },
  "author": "sugar-cat7",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@types/node": "^24.0.0",
    "knip": "^5.82.1",
    "lefthook": "^1.13.4",
    "semantic-release": "24.2.9",
    "textlint": "^15.5.2",
    "textlint-rule-write-good": "^2.0.0",
    "turbo": "2.6.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "pnpm": ">=9.15.9",
    "node": ">=20.18.0"
  },
  "workspaces": [
    "api",
    "dayjs",
    "errors",
    "logging"
  ]
