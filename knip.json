{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "api": {
      "project": "src/**/*.ts"
    },
    "dayjs": {
      "project": "**/*.ts"
    },
    "errors": {
      "project": "**/*.ts"
    },
    "logging": {
      "project": "**/*.ts"
    }
  },
  "ignoreBinaries": [],
  "ignoreDependencies": ["lefthook", "textlint-rule-write-good"],
  "ignoreExportsUsedInFile": true
}
